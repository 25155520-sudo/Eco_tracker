# ============================================================
# 🌍 EcoTracker - Environment Variables (EXAMPLE)
# ============================================================
# Copy this file to .env and fill in your own API keys.
# Never commit your real .env file to git or share it publicly.
# ============================================================

# 🔹 Climatiq API — Carbon emission calculations
# Get your key at: https://www.climatiq.io/
CLIMATIQ_API_KEY=your_climatiq_api_key_here

# 🔹 Global Forest Watch API — Deforestation & forest coverage
# Get your key at: https://www.globalforestwatch.org/
GLOBAL_FOREST_WATCH_API_KEY=your_gfw_api_key_here

# 🔹 World Bank API — Global stats (no key required, but placeholder for future)
# Docs: https://datahelpdesk.worldbank.org/knowledgebase/articles/889392
WORLD_BANK_API_KEY=no_key_required

# 🔹 Our World in Data (OWID) — Plastic & environmental stats
# Docs: https://ourworldindata.org/
OWID_API_KEY=no_key_required

# 🔹 OpenStreetMap / Nominatim — Geocoding & movement
# Docs: https://nominatim.org/release-docs/develop/api/Overview/
NOMINATIM_API_KEY=no_key_required

# 🔹 Groq AI — Insights & predictions
# Get your key at: https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here

# 🔹 App Settings
APP_DEBUG=True
APP_HOST=0.0.0.0
APP_PORT=8501
